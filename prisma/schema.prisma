generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rol {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  usuarios  Usuario[]
}

model Usuario {
  id                          Int                         @id @default(autoincrement())
  nombre                      String
  email                       String                      @unique
  password                    String
  rolId                       Int
  sucursalId                  Int?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  depositos                   Deposito[]
  fondosCajaInicial           FondoCajaInicial[]
  movimientos                 Movimiento[]
  movimientosDiarios          MovimientoDiario[]
  movimientosDiariosHistorial MovimientoDiarioHistorial[]
  pedidosActualizados         PedidoEspecial[]            @relation("PedidoActualizadoPor")
  pedidosCreados              PedidoEspecial[]            @relation("PedidoCreadoPor")
  pedidosEspeciales           PedidoEspecial[]
  rol                         Rol                         @relation(fields: [rolId], references: [id])
  sucursal                    Sucursal?                   @relation("UsuarioSucursalPrincipal", fields: [sucursalId], references: [id])
  sucursales                  UsuarioSucursal[]
  garantias                   Garantia[]
  mercaderias                 Mercaderia[]
  historialPedidos            PedidoEspecialHistorial[]
  tpvs                        Tpv[]
}

model Sucursal {
  id                 Int                @id @default(autoincrement())
  nombre             String             @unique
  direccion          String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  depositos          Deposito[]
  fondosCajaInicial  FondoCajaInicial[]
  movimientos        Movimiento[]
  movimientosDiarios MovimientoDiario[]
  pedidosEspeciales  PedidoEspecial[]
  usuarios           Usuario[]          @relation("UsuarioSucursalPrincipal")
  usuariosAsignados  UsuarioSucursal[]
  garantias          Garantia[]
  mercaderias        Mercaderia[]
  tpvs               Tpv[]
}

model FormaDePago {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  movimientos Movimiento[]
}

model TipoGasto {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  movimientos Movimiento[]
}

model Movimiento {
  id            Int            @id @default(autoincrement())
  fecha         DateTime       @default(now())
  monto         Float
  descripcion   String
  tipoGastoId   Int?
  sucursalId    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  formaDePagoId Int?
  tipo          MovimientoTipo
  imagen        String?
  usuarioId     Int?
  formaDePago   FormaDePago?   @relation(fields: [formaDePagoId], references: [id])
  sucursal      Sucursal       @relation(fields: [sucursalId], references: [id])
  tipoGasto     TipoGasto?     @relation(fields: [tipoGastoId], references: [id])
  usuario       Usuario?       @relation(fields: [usuarioId], references: [id])
}

model MovimientoDiario {
  id             Int                         @id @default(autoincrement())
  fecha          DateTime                    @default(now())
  ventasBrutas   Float                       @default(0)
  efectivo       Float                       @default(0)
  credito        Float                       @default(0)
  abonosCredito  Float                       @default(0)
  recargas       Float                       @default(0)
  pagoTarjeta    Float                       @default(0)
  transferencias Float                       @default(0)
  gastos         Float                       @default(0)
  saldoDia       Float                       @default(0)
  observaciones  String?
  sucursalId     Int
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  usuarioId      Int?
  depositos      Float                       @default(0)
  fondoInicial   Float                       @default(0)
  sucursal       Sucursal                    @relation(fields: [sucursalId], references: [id])
  usuario        Usuario?                    @relation(fields: [usuarioId], references: [id])
  historial      MovimientoDiarioHistorial[]

  @@unique([fecha, sucursalId])
}

model MovimientoDiarioHistorial {
  id                 Int              @id @default(autoincrement())
  movimientoDiarioId Int
  usuarioId          Int
  campoModificado    String
  valorAnterior      String
  valorNuevo         String
  fechaCambio        DateTime         @default(now())
  observaciones      String?
  movimientoDiario   MovimientoDiario @relation(fields: [movimientoDiarioId], references: [id], onDelete: Cascade)
  usuario            Usuario          @relation(fields: [usuarioId], references: [id])
}

model Deposito {
  id         Int      @id @default(autoincrement())
  fecha      DateTime @default(now())
  sucursalId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  monto      Float
  imagen     String?
  usuarioId  Int?
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
}

model FondoCajaInicial {
  id         Int      @id @default(autoincrement())
  monto      Float
  fecha      DateTime @default(now())
  sucursalId Int
  usuarioId  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@unique([fecha, sucursalId])
}

model PedidoEspecial {
  id             Int                       @id @default(autoincrement())
  descripcion    String
  sucursalId     Int
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  anticipo       Float
  cantidad       Int
  codigo         String
  estado         String                    @default("Pendiente")
  fechaEntrega   DateTime?
  fechaPedido    DateTime                  @default(now())
  marca          String
  precioVenta    Float
  total          Float
  usuarioId      Int
  comprobante    String?
  actualizadoEn  DateTime                  @updatedAt
  actualizadoPor Int?
  creadoEn       DateTime                  @default(now())
  creadoPor      Int
  actualizador   Usuario?                  @relation("PedidoActualizadoPor", fields: [actualizadoPor], references: [id])
  creador        Usuario                   @relation("PedidoCreadoPor", fields: [creadoPor], references: [id])
  sucursal       Sucursal                  @relation(fields: [sucursalId], references: [id])
  usuario        Usuario                   @relation(fields: [usuarioId], references: [id])
  historial      PedidoEspecialHistorial[]
}

model UsuarioSucursal {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  sucursalId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, sucursalId])
}

model PedidoEspecialHistorial {
  id              Int            @id @default(autoincrement())
  pedidoId        Int
  accion          String
  descripcion     String
  datosAnteriores Json?
  datosNuevos     Json?
  usuarioId       Int
  fechaAccion     DateTime       @default(now())
  pedido          PedidoEspecial @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])

  @@map("pedidos_especiales_historial")
}

model Mercaderia {
  id         Int      @id @default(autoincrement())
  fecha      DateTime
  tipo       String
  referencia String
  entrega    String
  recibe     String
  monto      Float
  sucursalId Int
  usuarioId  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("mercaderias")
}

model Garantia {
  id                     Int       @id @default(autoincrement())
  fechaRegistro          DateTime
  estado                 String
  sucursalId             Int
  usuarioId              Int
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  cantidad               Int
  cliente                String
  comentarios            String?
  descripcion            String
  fechaEntregaCliente    DateTime?
  fechaEntregaFabricante DateTime?
  fechaRegresoFabricante DateTime?
  fotoReciboEntrega      String?
  marca                  String
  sku                    String
  sucursal               Sucursal  @relation(fields: [sucursalId], references: [id])
  usuario                Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("garantias")
}

model Tpv {
  id              Int      @id @default(autoincrement())
  fecha           DateTime
  quienCobro      String
  monto           Float
  estado          String
  foto            String?
  usuarioRegistro String
  sucursalId      Int
  usuarioId       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sucursal        Sucursal @relation(fields: [sucursalId], references: [id])
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("tpv")
}

enum MovimientoTipo {
  VENTA
  GASTO
  FONDO_CAJA
  DEPOSITO
}
